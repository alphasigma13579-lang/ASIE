# ASIE local runtime keys.
# Keep real values outside source control and outside the r11 package.

ASIE_ENV=local
ASIE_STRICT_OPEN_DATA_PROFILE=strict_open_data_only_v1
ASIE_ALLOW_EXTERNAL_FETCH=false
ASIE_API_PORT=8794

# AI providers are implementation mechanisms only; they cannot own numbers or verdicts.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Search/research helpers stay disabled until source terms are reviewed.
TAVILY_API_KEY=

# Future persistence/analytics providers.
DATABASE_URL=
PINECONE_API_KEY=
PINECONE_INDEX=
GOOGLE_ANALYTICS_MEASUREMENT_ID=
ZOHO_ANALYTICS_CLIENT_ID=
