  "formulas": [
    {
      "id": "FIN-RATE-001",
      "name": "effective_period_rate",
      "expression": "(1 + annual_effective_rate)^(1 / periods_per_year) - 1",
      "guardrails": ["annual_effective_rate>-1", "periods_per_year>0"]
    },
    {
      "id": "FIN-RATE-002",
      "name": "real_rate",
      "expression": "(1 + nominal_rate) / (1 + inflation_rate) - 1",
      "guardrails": ["inflation_rate>-1", "nominal_and_inflation_same_period"]
    },
    {
      "id": "FIN-REV-001",
      "name": "net_revenue",
      "expression": "units * price_ex_vat - discounts - returns",
      "aggregation_grain": "item_channel_period"
    },
    {
      "id": "FIN-COGS-001",
      "name": "unit_variable_cost",
      "expression": "sum(input_quantity_per_unit / yield * landed_input_cost) + other_variable_unit_cost",
      "guardrails": ["yield>0", "no_double_count_freight_or_duty"]
    },
    {
      "id": "FIN-MARGIN-001",
      "name": "contribution_margin",
      "expression": "net_revenue - variable_costs",
      "unit": "money"
    },
    {
      "id": "FIN-MARGIN-002",
      "name": "weighted_contribution_margin_ratio",
      "expression": "sum(contribution_margin_by_item) / sum(net_revenue_by_item)",
      "guardrails": ["total_net_revenue!=0"]
    },
    {
      "id": "FIN-BE-001",
      "name": "break_even_revenue",
      "expression": "fixed_cash_operating_costs / weighted_contribution_margin_ratio",
      "guardrails": ["weighted_contribution_margin_ratio>0"]
    },
    {
      "id": "FIN-PL-001",
      "name": "gross_profit",
      "expression": "net_revenue - cogs",
      "unit": "money"
    },
    {
      "id": "FIN-PL-002",
      "name": "ebitda",
      "expression": "net_revenue - cogs - operating_expenses_excluding_depreciation_amortization_interest_tax",
      "unit": "money"
    },
    {
      "id": "FIN-PL-003",
      "name": "ebit",
      "expression": "ebitda - depreciation - amortization - impairment_operating",
      "unit": "money"
    },
    {
      "id": "FIN-DEP-001",
      "name": "straight_line_depreciation",
      "expression": "(depreciable_cost - residual_value) / useful_life_periods",
      "guardrails": ["useful_life_periods>0", "starts_on_in_service_date", "component_level_when_material"]
    },
    {
      "id": "FIN-LEASE-001",
      "name": "initial_lease_liability",
      "expression": "sum(lease_payment_t / (1 + period_discount_rate)^t)",
      "guardrails": ["apply_only_under_selected_reporting_policy", "separate_service_components", "do_not_double_count_cash_rent"]
    },
    {
      "id": "FIN-HR-001",
      "name": "loaded_employee_cost",
      "expression": "basic + allowances + variable_pay + employer_contributions + insurance + recruitment_amortization + visa_permit + training + leave_cost + end_of_service_accrual",
      "guardrails": ["statutory_components_resolved_by_effective_dated_rule_engine"]
    },
    {
      "id": "FIN-WC-001",
      "name": "net_working_capital",
      "expression": "trade_receivables + eligible_inventory + other_operating_current_assets - trade_payables - other_operating_current_liabilities",
      "guardrails": ["exclude_cash_and_financing_items", "vat_treatment_consistent"]
    },
    {
      "id": "FIN-WC-002",
      "name": "receivables_from_dso",
      "expression": "credit_revenue * dso / days_in_period",
      "guardrails": ["credit_revenue_only", "period_alignment"]
    },
    {
      "id": "FIN-WC-003",
      "name": "inventory_from_dio",
      "expression": "eligible_cogs * dio / days_in_period",
      "guardrails": ["inventory_relevant_business_only"]
    },
    {
      "id": "FIN-WC-004",
      "name": "payables_from_dpo",
      "expression": "credit_purchases * dpo / days_in_period",
      "guardrails": ["credit_purchases_not_cogs_when_materially_different"]
    },
    {
      "id": "FIN-CF-001",
      "name": "cash_bridge",
      "expression": "opening_cash + cfo + cfi + cff",
      "output": "closing_cash"
    },
    {
      "id": "FIN-CF-002",
      "name": "fcff",
      "expression": "nopat + depreciation + amortization - capex - delta_nwc + approved_non_cash_adjustments",
      "guardrails": ["exclude_debt_draws_and_principal", "tax_from_tax_schedule"]
    },
    {
      "id": "FIN-CF-003",
      "name": "fcfe",
      "expression": "net_income + depreciation + amortization - capex - delta_nwc + net_borrowing + approved_non_cash_adjustments",
      "guardrails": ["equity_cash_flow_only"]
    },
    {
      "id": "FIN-CF-004",
      "name": "cfads",
      "expression": "operating_cash_before_financing - cash_taxes - maintenance_capex + approved_cfads_adjustments",
      "guardrails": ["definition_locked_per_financing_contract"]
    },
    {
      "id": "FIN-VAL-001",
      "name": "npv",
      "expression": "sum(cash_flow_t / (1 + discount_rate)^t)",
      "guardrails": ["cash_flow_and_discount_basis_match", "include_t0", "use_xnpv_for_irregular_dates"]
    },
    {
      "id": "FIN-VAL-002",
      "name": "xnpv",
      "expression": "sum(cash_flow_i / (1 + annual_rate)^((date_i-date_0)/day_count_basis))",
      "guardrails": ["dates_monotonic", "document_day_count_basis"]
    },
    {
      "id": "FIN-VAL-003",
      "name": "irr",
      "expression": "solve r where npv(r)=0",
      "guardrails": ["detect_sign_changes", "report_multiple_or_no_root", "do_not_use_as_sole_decision_metric"]
    },
    {
      "id": "FIN-VAL-004",
      "name": "mirr",
      "expression": "(future_value_positive_cash_flows / -present_value_negative_cash_flows)^(1/n) - 1",
      "guardrails": ["document_finance_rate", "document_reinvestment_rate"]
    },
    {
      "id": "FIN-VAL-005",
      "name": "profitability_index",
      "expression": "present_value_future_cash_inflows / absolute_initial_investment",
      "guardrails": ["initial_investment>0", "same_discount_basis_as_npv"]
    },
    {
      "id": "FIN-VAL-006",
      "name": "wacc",
      "expression": "equity_weight * cost_of_equity + debt_weight * pre_tax_cost_of_debt * (1 - applicable_tax_shield_rate)",
      "guardrails": ["market_or_approved_weights", "tax_shield_only_when_applicable", "not_for_equity_cash_flow"]
    },
    {
      "id": "FIN-DEBT-001",
      "name": "period_dscr",
      "expression": "cfads / debt_service",
      "guardrails": ["debt_service>0", "definition_matches_financing_contract"]
    },
    {
      "id": "FIN-DEBT-002",
      "name": "llcr",
      "expression": "npv_of_cfads_over_remaining_loan_life_at_approved_debt_rate / opening_debt_balance",
      "guardrails": ["opening_debt_balance>0", "loan_life_only"]
    },
    {
      "id": "FIN-LIQ-001",
      "name": "funding_gap",
      "expression": "max(0, required_minimum_cash - minimum_pre_funding_cash)",
      "guardrails": ["include_timing_not_annual_net_only"]
    },
    {
      "id": "RISK-MC-001",
      "name": "monte_carlo_feasibility_gate_probability",
      "expression": "count(valid_simulation where all applicable approved gates pass) / count(valid_simulations)",
      "guardrails": ["not_success_probability_label", "non_applicable_gates_excluded", "convergence_required", "evidence_backed_distributions"]
    },
    {
      "id": "RISK-SW-001",
      "name": "switching_value",
      "expression": "solve input_value where selected_decision_metric reaches decision_boundary",
      "guardrails": ["boundary_and_solver_documented", "report_non_monotonic_cases"]
    },
    {
      "id": "EVD-QUAL-001",
      "name": "evidence_coverage",
      "expression": "sum(materiality_weight for valid_supported_material_assumptions) / sum(materiality_weight for all_material_assumptions)",
      "guardrails": ["weights_governed", "quality_and_freshness_reported_separately", "ai_not_source"]
    },
    {
      "id": "FSDP-KPI-001",
      "name": "execution_readiness_index",
      "expression": "sum(weight of passed applicable execution gates) / sum(weight of applicable execution gates)",
      "guardrails": ["deterministic", "weights_versioned", "critical_gate_failure_visible"]
    },
    {
      "id": "FSDP-KPI-002",
      "name": "commercial_acceptance_index",
      "expression": "sum(weight of passed applicable commercial evidence gates) / sum(weight of applicable commercial evidence gates)",
      "guardrails": ["sector_specific", "demand_and_willingness_to_pay_evidence_required"]
    },
    {
      "id": "FSDP-KPI-003",
      "name": "technical_robustness_index",
      "expression": "sum(weight of controlled applicable critical failure modes) / sum(weight of applicable critical failure modes)",
      "guardrails": ["critical_uncontrolled_failure_visible", "sector_specific"]
    },
    {
      "id": "FSDP-KPI-004",
      "name": "transition_readiness_index",
      "expression": "sum(weight of completed applicable next_stage_prerequisites) / sum(weight of applicable next_stage_prerequisites)",
      "guardrails": ["next_stage_explicit", "blocked_prerequisites_visible"]
    },
    {
      "id": "FSDP-KPI-005",
      "name": "pressure_survival_index",
      "expression": "sum(weight of passed valid applicable stress tests) / sum(weight of valid applicable stress tests)",
      "guardrails": ["stress_catalog_versioned", "not_equal_to_monte_carlo_probability"]
    }
  ],
